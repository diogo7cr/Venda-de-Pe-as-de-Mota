@page
@model MotoPartsShop.Pages.Admin.Cupoes.IndexModel
@{
    ViewData["Title"] = "Gestão de Cupões";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">🏷️ Gestão de Cupões</h1>
            <p class="text-muted">Crie e gerencie códigos de desconto</p>
        </div>
        <div>
            <a asp-page="/Dashboard" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
            <a asp-page="Create" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle"></i> Criar Cupão
            </a>
        </div>
    </div>

    <!-- ESTATÍSTICAS -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card stat-card border-success">
                <div class="card-body text-center">
                    <div class="stat-icon-large bg-success mb-2">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <h3 class="mb-0">@Model.CupoesAtivos</h3>
                    <p class="text-muted mb-0">Cupões Ativos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-danger">
                <div class="card-body text-center">
                    <div class="stat-icon-large bg-danger mb-2">
                        <i class="bi bi-x-circle"></i>
                    </div>
                    <h3 class="mb-0">@Model.CupoesExpirados</h3>
                    <p class="text-muted mb-0">Cupões Expirados</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-info">
                <div class="card-body text-center">
                    <div class="stat-icon-large bg-info mb-2">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <h3 class="mb-0">@Model.TotalUtilizacoes</h3>
                    <p class="text-muted mb-0">Total de Utilizações</p>
                </div>
            </div>
        </div>
    </div>

    <!-- LISTA DE CUPÕES -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Lista de Cupões (@Model.Cupoes.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Cupoes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Descrição</th>
                                <th>Desconto</th>
                                <th>Valor Mínimo</th>
                                <th>Validade</th>
                                <th>Utilizações</th>
                                <th>Estado</th>
                                <th width="150" class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cupao in Model.Cupoes)
                            {
                                var hoje = DateTime.Now.Date;
                                var expirado = cupao.DataFim < hoje;
                                var valido = cupao.Ativo && !expirado;

                                <tr class="@(expirado ? "table-secondary" : "")">
                                    <td>
                                        <strong class="badge bg-dark fs-6">@cupao.Codigo</strong>
                                    </td>
                                    <td>@cupao.Descricao</td>
                                    <td>
                                        <span class="badge bg-success">@cupao.PercentagemDesconto%</span>
                                    </td>
                                    <td>€@cupao.ValorMinimo.ToString("F2")</td>
                                    <td>
                                        <small>
                                            @cupao.DataInicio.ToString("dd/MM/yyyy")<br>
                                            <i class="bi bi-arrow-down"></i><br>
                                            @cupao.DataFim.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        @cupao.UtilizacoesAtuais
                                        @if (cupao.LimiteUtilizacoes.HasValue)
                                        {
                                            <text> / @cupao.LimiteUtilizacoes</text>
                                        }
                                        else
                                        {
                                            <text> / ∞</text>
                                        }
                                    </td>
                                    <td>
                                        @if (expirado)
                                        {
                                            <span class="badge bg-secondary">Expirado</span>
                                        }
                                        else if (!cupao.Ativo)
                                        {
                                            <span class="badge bg-warning text-dark">Inativo</span>
                                        }
                                        else if (cupao.LimiteUtilizacoes.HasValue && 
                                                 cupao.UtilizacoesAtuais >= cupao.LimiteUtilizacoes.Value)
                                        {
                                            <span class="badge bg-danger">Esgotado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Ativo</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a asp-page="Edit" asp-route-id="@cupao.Id" 
                                               class="btn btn-sm btn-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-page="Delete" asp-route-id="@cupao.Id" 
                                               class="btn btn-sm btn-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-ticket-perforated" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">Nenhum cupão criado</h4>
                    <p>Crie o seu primeiro cupão de desconto!</p>
                    <a asp-page="Create" class="btn btn-success mt-2">
                        <i class="bi bi-plus-circle"></i> Criar Cupão
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
.stat-card {
    border: none;
    box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    border-radius: 10px;
    transition: transform 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 25px rgba(0,0,0,0.12);
}

.stat-icon-large {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: white;
}

.table td {
    vertical-align: middle;
}
</style>