@page
@model MotoPartsShop.Pages.NotificarStockModel

@{
    ViewData["Title"] = "Notificar quando disponível";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">
                        <i class="bi bi-bell-fill"></i> Notificações de Stock
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.Mensagem))
                    {
                        <div class="alert @(Model.Sucesso ? "alert-success" : "alert-warning") alert-dismissible fade show" role="alert">
                            <i class="bi @(Model.Sucesso ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                            @Model.Mensagem
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (!Model.Sucesso)
                    {
                        <div class="text-center mb-4">
                            <i class="bi bi-box-seam text-muted" style="font-size: 4rem;"></i>
                            <h5 class="mt-3">@Model.PecaNome</h5>
                            <p class="text-muted">Este produto está temporariamente esgotado</p>
                        </div>

                        <form method="post">
                            <input type="hidden" asp-for="PecaId" />
                            
                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-bold">
                                    <i class="bi bi-envelope-fill"></i> Email para notificação:
                                </label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg" 
                                       placeholder="seu@email.com" required />
                                <div class="form-text">
                                    Vamos enviar-te um email quando o produto voltar ao stock
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-bell-fill"></i> Ativar Notificação
                                </button>
                                <a asp-page="/Pecas/Details" asp-route-id="@Model.PecaId" 
                                   class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left"></i> Voltar ao Produto
                                </a>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="text-center">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                            <div class="mt-4">
                                <a asp-page="/Pecas/Index" class="btn btn-primary btn-lg">
                                    <i class="bi bi-grid"></i> Voltar ao Catálogo
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- INFO BOX -->
            <div class="card mt-4 border-info">
                <div class="card-body">
                    <h6 class="fw-bold"><i class="bi bi-info-circle-fill text-info"></i> Como funciona?</h6>
                    <ul class="small mb-0">
                        <li>Vais receber um email quando o produto voltar ao stock</li>
                        <li>A notificação é enviada automaticamente</li>
                        <li>Podes cancelar a notificação a qualquer momento</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>