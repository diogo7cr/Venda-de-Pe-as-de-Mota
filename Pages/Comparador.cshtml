@page
@model MotoPartsShop.Pages.ComparadorModel
@{
    ViewData["Title"] = "Comparador de Peças";
}

<div class="container py-5">
    <h1 class="display-5 fw-bold mb-4">
        <i class="bi bi-arrow-left-right"></i> Comparador de Peças
    </h1>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-x-circle-fill"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Aviso"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Aviso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Itens.Any())
    {
        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <p class="text-muted mb-0">
                    <i class="bi bi-info-circle"></i> Comparando <strong>@Model.Itens.Count</strong> de 4 peças
                </p>
                <form method="post" asp-page-handler="Limpar">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i> Limpar Tudo
                    </button>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover comparison-table">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 200px;">Características</th>
                        @foreach (var item in Model.Itens)
                        {
                            <th class="text-center">
                                <form method="post" asp-page-handler="Remover" class="float-end">
                                    <input type="hidden" name="pecaId" value="@item.PecaId" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Remover">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <!-- IMAGEM -->
                    <tr>
                        <td class="fw-bold bg-light">Imagem</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">
                                <img src="@item.ImagemUrl" alt="@item.Nome" 
                                     style="width: 150px; height: 150px; object-fit: cover; border-radius: 10px;">
                            </td>
                        }
                    </tr>

                    <!-- NOME -->
                    <tr>
                        <td class="fw-bold bg-light">Nome</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td>
                                <strong>@item.Nome</strong><br>
                                <small class="text-muted">Ref: @item.Referencia</small>
                            </td>
                        }
                    </tr>

                    <!-- PREÇO -->
                    <tr>
                        <td class="fw-bold bg-light">Preço</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">
                                <h4 class="text-success mb-0">€@item.Preco</h4>
                            </td>
                        }
                    </tr>

                    <!-- STOCK -->
                    <tr>
                        <td class="fw-bold bg-light">Stock</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">
                                @if (item.Stock > 0)
                                {
                                    <span class="badge bg-success fs-6">@item.Stock unidades</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Esgotado</span>
                                }
                            </td>
                        }
                    </tr>

                    <!-- CATEGORIA -->
                    <tr>
                        <td class="fw-bold bg-light">Categoria</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">@item.CategoriaNome</td>
                        }
                    </tr>

                    <!-- MARCA -->
                    <tr>
                        <td class="fw-bold bg-light">Marca</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">@item.MarcaNome</td>
                        }
                    </tr>

                    <!-- MODELO -->
                    <tr>
                        <td class="fw-bold bg-light">Modelo</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">@item.ModeloNome</td>
                        }
                    </tr>

                    <!-- TIPO -->
                    <tr>
                        <td class="fw-bold bg-light">Tipo</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">
                                @if (item.PecaOriginal)
                                {
                                    <span class="badge bg-primary">Original</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Compatível</span>
                                }
                            </td>
                        }
                    </tr>

                    <!-- PESO -->
                    <tr>
                        <td class="fw-bold bg-light">Peso</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">
                                @if (item.Peso.HasValue)
                                {
                                    <span>@item.Peso kg</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                        }
                    </tr>

                    <!-- AÇÕES -->
                    <tr>
                        <td class="fw-bold bg-light">Ações</td>
                        @foreach (var item in Model.Itens)
                        {
                            <td class="text-center">
                                <div class="d-grid gap-2">
                                    <a asp-page="/Pecas/Details" asp-route-id="@item.PecaId" 
                                       class="btn btn-info btn-sm">
                                        <i class="bi bi-eye"></i> Ver Detalhes
                                    </a>
                                    <form method="post" asp-page="/Carrinho" asp-page-handler="Adicionar">
                                        <input type="hidden" name="pecaId" value="@item.PecaId" />
                                        <input type="hidden" name="nome" value="@item.Nome" />
                                        <input type="hidden" name="preco" value="@item.Preco" />
                                        <input type="hidden" name="imagemUrl" value="@item.ImagemUrl" />
                                        <button type="submit" class="btn btn-success btn-sm w-100"
                                                @(item.Stock == 0 ? "disabled" : "")>
                                            <i class="bi bi-cart-plus"></i> Adicionar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="alert alert-info mt-4">
            <i class="bi bi-lightbulb"></i> 
            <strong>Dica:</strong> Podes adicionar até 4 peças para comparar. 
            Volta ao catálogo e clica no botão de comparação nas peças que queres adicionar.
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center py-5">
            <i class="bi bi-arrow-left-right" style="font-size: 4rem;"></i>
            <h4 class="mt-3">Nenhuma peça para comparar</h4>
            <p>Adiciona peças ao comparador para veres as diferenças lado a lado!</p>
            <a asp-page="/Pecas/Index" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-grid"></i> Ir ao Catálogo
            </a>
        </div>
    }
</div>

<style>
    .comparison-table {
        background: white;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        border-radius: 10px;
        overflow: hidden;
    }

    .comparison-table td {
        vertical-align: middle;
        padding: 1rem;
    }

    .comparison-table .bg-light {
        background: #f8f9fa !important;
    }
</style>