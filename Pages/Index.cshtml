@page
@model IndexModel
@{
    ViewData["Title"] = "MotoPartsShop - O Teu Catálogo de Peças";
}

<!-- HERO SECTION COM CARROSSEL -->
<section class="hero-section">
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
        </div>
        
        <div class="carousel-inner">
            <!-- SLIDE 1 -->
            <div class="carousel-item active">
                <div class="hero-slide" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="container">
                        <div class="row align-items-center min-vh-70">
                            <div class="col-lg-6 text-white">
                                <h1 class="display-3 fw-bold mb-4 animate-slide-in">
                                    🏍️ Peças de Qualidade<br>Para a Tua Mota
                                </h1>
                                <p class="lead mb-4">
                                    Mais de <strong>8 peças</strong> disponíveis das melhores marcas
                                </p>
                                <div class="d-flex gap-3">
                                    <a asp-page="/Pecas/Index" class="btn btn-light btn-lg px-4 py-3">
                                        <i class="bi bi-grid-fill"></i> Ver Catálogo
                                    </a>
                                    <a asp-page="/Dashboard" class="btn btn-outline-light btn-lg px-4 py-3">
                                        <i class="bi bi-bar-chart"></i> Dashboard
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=800" 
                                     alt="Mota" class="img-fluid hero-image">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- SLIDE 2 -->
            <div class="carousel-item">
                <div class="hero-slide" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <div class="container">
                        <div class="row align-items-center min-vh-70">
                            <div class="col-lg-6 text-white">
                                <h1 class="display-3 fw-bold mb-4">
                                    💰 Descontos até 30%
                                </h1>
                                <p class="lead mb-4">
                                    Promoções especiais em peças selecionadas
                                </p>
                                <a asp-page="/Pecas/Index" class="btn btn-light btn-lg px-4 py-3">
                                    <i class="bi bi-tag-fill"></i> Ver Promoções
                                </a>
                            </div>
                            <div class="col-lg-6">
                                <img src="https://images.unsplash.com/photo-1568772585407-9361f9bf3a87?w=800" 
                                     alt="Promoções" class="img-fluid hero-image">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- SLIDE 3 -->
            <div class="carousel-item">
                <div class="hero-slide" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <div class="container">
                        <div class="row align-items-center min-vh-70">
                            <div class="col-lg-6 text-white">
                                <h1 class="display-3 fw-bold mb-4">
                                    🚚 Envio Grátis
                                </h1>
                                <p class="lead mb-4">
                                    Em compras acima de €50. Entrega em 3-5 dias úteis.
                                </p>
                                <a asp-page="/Pecas/Index" class="btn btn-light btn-lg px-4 py-3">
                                    <i class="bi bi-cart-fill"></i> Comprar Agora
                                </a>
                            </div>
                            <div class="col-lg-6">
                                <img src="https://images.unsplash.com/photo-1449426468159-d96dbf08f19f?w=800" 
                                     alt="Envio" class="img-fluid hero-image">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- CONTROLES -->
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-icon">
                <i class="bi bi-chevron-left"></i>
            </span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-icon">
                <i class="bi bi-chevron-right"></i>
            </span>
        </button>
    </div>
</section>

<!-- ✅ BANNER DE PROMOÇÕES/CUPÕES - NOVO! -->
@if (Model.CupoesAtivos != null && Model.CupoesAtivos.Any())
{
    <section class="promocoes-section py-4">
        <div class="container">
            <div id="promocoesCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.CupoesAtivos.Count; i++)
                    {
                        var cupao = Model.CupoesAtivos[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="promo-card">
                                <div class="promo-content">
                                    <div class="promo-icon">
                                        <i class="bi bi-ticket-perforated"></i>
                                    </div>
                                    <div class="promo-text">
                                        <h3>🎉 @cupao.Descricao</h3>
                                        <p class="mb-2">
                                            Use o cupão <strong class="cupao-code">@cupao.Codigo</strong> 
                                            e ganhe <strong>@cupao.PercentagemDesconto% de desconto</strong>!
                                        </p>
                                        <p class="mb-0">
                                            <small>
                                                <i class="bi bi-calendar-event"></i> 
                                                Válido até @cupao.DataFim.ToString("dd/MM/yyyy")
                                                @if (cupao.ValorMinimo > 0)
                                                {
                                                    <text> | Compra mínima: €@cupao.ValorMinimo.ToString("F2")</text>
                                                }
                                            </small>
                                        </p>
                                    </div>
                                    <div class="promo-action">
                                        <a asp-page="/Pecas/Index" class="btn btn-light btn-lg">
                                            <i class="bi bi-cart"></i> Comprar Agora
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (Model.CupoesAtivos.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#promocoesCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Anterior</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#promocoesCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Próximo</span>
                    </button>
                }
            </div>
        </div>
    </section>
}

<!-- ESTATÍSTICAS -->
