                    </div>
                    <h3 class="stat-number" data-target="8">0</h3>
                    <p class="stat-label">Peças Disponíveis</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card text-center">
                    <div class="stat-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <h3 class="stat-number" data-target="6">0</h3>
                    <p class="stat-label">Marcas</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card text-center">
                    <div class="stat-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3 class="stat-number" data-target="500">0</h3>
                    <p class="stat-label">Clientes Satisfeitos</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card text-center">
                    <div class="stat-icon">
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <h3 class="stat-number" data-target="98">0</h3>
