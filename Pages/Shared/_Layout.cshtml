@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<MotoPartsShop.Resources.SharedResources> Localizer

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.Culture.TwoLetterISOLanguageName ?? "pt";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>@ViewData["Title"] - MotoPartsShop</title>
    <script type="importmap"></script>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MotoPartsShop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    
    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }
        
        /* ✅ NAVBAR COM FUNDO ESCURO BEM VISÍVEL */
        .navbar-custom {
            background: #1a252f !important;
            padding: 0.8rem 0;
            box-shadow: 0 2px 15px rgba(0,0,0,0.3);
        }
        
        .navbar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: white !important;
            letter-spacing: 0.5px;
        }
        
        /* Links e dropdowns - TEXTO BEM VISÍVEL */
        .nav-link,
        .dropdown-toggle {
            color: #ffffff !important;
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            text-shadow: 0 1px 2px rgba(0,0,0,0.2);
        }
        
        .nav-link:hover,
        .dropdown-toggle:hover {
            color: #3498db !important;
            background: rgba(255,255,255,0.15);
            border-radius: 6px;
        }
        
        /* Dropdown menu - FUNDO ESCURO */
        .dropdown-menu {
            background: #2c3e50 !important;
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 5px 20px rgba(0,0,0,0.4);
            border-radius: 8px;
            padding: 0.5rem;
            margin-top: 0.5rem;
        }
        
        .dropdown-item {
            color: #ffffff !important;
            border-radius: 6px;
            padding: 0.6rem 1rem;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }
        
        .dropdown-item:hover {
            background: rgba(52, 152, 219, 0.4) !important;
            color: #ffffff !important;
            transform: translateX(5px);
        }
        
        .dropdown-item i {
            width: 20px;
            margin-right: 8px;
        }
        
        /* SELETOR DE IDIOMA - MAIS VISÍVEL */
        .language-selector {
            background: rgba(255,255,255,0.15);
            border-radius: 8px;
            padding: 5px 10px;
        }
        
        .language-selector .dropdown-toggle {
            background: transparent;
            border: none;
            color: #ffffff !important;
            display: flex;
            align-items: center;
            gap: 5px;
            font-weight: 600;
            padding: 0.5rem 1rem;
            text-shadow: 0 1px 2px rgba(0,0,0,0.3);
        }
        
        .language-selector .dropdown-toggle:hover {
            background: rgba(255,255,255,0.25);
        }
        
        .language-selector .dropdown-menu {
            background: #ffffff !important;
            border: 1px solid rgba(0,0,0,0.1);
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            border-radius: 8px;
            padding: 0.5rem;
        }
        
        .language-selector .dropdown-item {
            color: #2c3e50 !important;
            border-radius: 6px;
            padding: 0.5rem 1rem;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        
        .language-selector .dropdown-item:hover {
            background: #e8f4f8 !important;
            transform: translateX(5px);
        }
        
        .language-selector .dropdown-item.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
            color: white !important;
        }
        
        /* FOOTER */
        .footer-custom {
            background: linear-gradient(135deg, #1A1A2E 0%, #0f0f1e 100%);
            color: rgba(255,255,255,0.8);
            padding: 2rem 0;
            margin-top: 4rem;
        }
        
        .footer-custom a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        .footer-custom a:hover {
            color: #3498db;
        }

        /* DARK MODE STYLES */
        .dark-mode-toggle {
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            border: 2px solid rgba(255,255,255,0.3);
            background: transparent;
        }

        .dark-mode-toggle:hover {
            background: rgba(255,255,255,0.2);
            transform: scale(1.1);
        }

        /* DARK MODE VARIABLES */
        body.dark-mode {
            --primary-color: #FF8C42;
            --secondary-color: #00A8E8;
            --dark-color: #0F1419;
            --light-color: #15202B;
            --success-color: #06D6A0;
            --bg-color: #15202B;
            --card-bg: #192734;
            --text-color: #E7E9EA;
            --text-muted: #8B98A5;
            --border-color: #38444D;
        }

        body.dark-mode {
            background-color: var(--bg-color);
            color: var(--text-color);
        }

        body.dark-mode .navbar-custom {
            background: linear-gradient(135deg, #0F1419 0%, #192734 100%);
        }

        body.dark-mode .footer-custom {
            background: linear-gradient(135deg, #0F1419 0%, #0a0e13 100%);
        }

        body.dark-mode .card,
        body.dark-mode .product-card,
        body.dark-mode .stat-card,
        body.dark-mode .category-card,
        body.dark-mode .team-card,
        body.dark-mode .filter-card {
            background-color: var(--card-bg);
            color: var(--text-color);
            border-color: var(--border-color);
        }

        body.dark-mode .form-control,
        body.dark-mode .form-select {
            background-color: #192734;
            color: var(--text-color);
            border-color: var(--border-color);
        }

        body.dark-mode .form-control:focus,
        body.dark-mode .form-select:focus {
            background-color: #192734;
            color: var(--text-color);
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.25rem rgba(255, 140, 66, 0.25);
        }

        body.dark-mode .form-control::placeholder {
            color: var(--text-muted);
        }

        body.dark-mode .table {
            color: var(--text-color);
        }

        body.dark-mode .table-hover tbody tr:hover {
            background-color: rgba(255, 255, 255, 0.05);
        }

        body.dark-mode .table-dark {
            background-color: #0F1419;
            color: var(--text-color);
        }

        body.dark-mode .alert-info {
            background-color: rgba(0, 168, 232, 0.15);
            color: #00A8E8;
            border-color: rgba(0, 168, 232, 0.3);
        }

        body.dark-mode .alert-warning {
            background-color: rgba(255, 193, 7, 0.15);
            color: #FFC107;
            border-color: rgba(255, 193, 7, 0.3);
        }

        body.dark-mode .alert-danger {
            background-color: rgba(220, 53, 69, 0.15);
            color: #DC3545;
            border-color: rgba(220, 53, 69, 0.3);
        }

        body.dark-mode .alert-success {
            background-color: rgba(6, 214, 160, 0.15);
            color: #06D6A0;
            border-color: rgba(6, 214, 160, 0.3);
        }

        body.dark-mode .badge {
            border: 1px solid var(--border-color);
        }

        body.dark-mode .text-muted {
            color: var(--text-muted) !important;
        }

        body.dark-mode .text-dark {
            color: var(--text-color) !important;
        }

        body.dark-mode .dropdown-menu {
            background-color: var(--card-bg);
            border-color: var(--border-color);
        }

        body.dark-mode .dropdown-item {
            color: var(--text-color);
        }

        body.dark-mode .dropdown-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: var(--text-color);
        }

        body.dark-mode .dropdown-divider {
            border-color: var(--border-color);
        }

        body.dark-mode .btn-outline-primary {
            color: var(--primary-color);
            border-color: var(--primary-color);
        }

        body.dark-mode .btn-outline-primary:hover {
            background-color: var(--primary-color);
            color: white;
        }

        body.dark-mode .btn-outline-secondary {
            color: var(--text-color);
            border-color: var(--border-color);
        }

        body.dark-mode .btn-outline-secondary:hover {
            background-color: var(--border-color);
            color: var(--text-color);
        }

        body.dark-mode .modal-content {
            background-color: var(--card-bg);
            color: var(--text-color);
        }

        body.dark-mode .modal-header {
            border-color: var(--border-color);
        }

        body.dark-mode .modal-footer {
            border-color: var(--border-color);
        }

        body.dark-mode .pagination .page-link {
            background-color: var(--card-bg);
            color: var(--primary-color);
            border-color: var(--border-color);
        }

        body.dark-mode .pagination .page-link:hover {
            background-color: var(--primary-color);
            color: white;
        }

        body.dark-mode .pagination .page-item.active .page-link {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        body.dark-mode .list-group-item {
            background-color: var(--card-bg);
            color: var(--text-color);
            border-color: var(--border-color);
        }

        body.dark-mode .hero-slide {
            color: var(--text-color);
        }

        body.dark-mode .cta-box {
            background: linear-gradient(135deg, #192734 0%, #0F1419 100%);
        }

        body,
        .card,
        .form-control,
        .form-select,
        .btn,
        .alert,
        .table,
        .dropdown-menu,
        .list-group-item {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }

        /* FORÇA ESCONDER BADGE ORIGINAL DO PERFIL */
.navbar-nav .badge,
.navbar .badge,
header .badge {
    display: none !important;
    visibility: hidden !important;
}

/* MAS MANTÉM BADGES NOS CARDS */
.product-card .badge,
.product-badges .badge {
    display: inline-block !important;
    visibility: visible !important;
}
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container-fluid">
                <!-- LOGO -->
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    🏍️ MOTOPARTSSHOP
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                        style="background: rgba(255,255,255,0.3); border: none;">
                    <i class="bi bi-list" style="color: white; font-size: 1.5rem;"></i>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- MENU ESQUERDA -->
                    <ul class="navbar-nav me-auto">
                        
                        <!-- 🔽 DROPDOWN GESTÃO - SÓ PARA ADMIN/GESTOR -->
                        @if (User.IsInRole("Admin") || User.IsInRole("Gestor"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-folder-fill"></i> Gestão
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Categorias/Index">
                                            <i class="bi bi-tags-fill"></i> @Localizer["Category"]
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Marcas/Index">
                                            <i class="bi bi-building"></i> @Localizer["Brand"]
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Modelos/Index">
                                            <i class="bi bi-bicycle"></i> @Localizer["Model"]
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        
                        <!-- 🔽 DROPDOWN ADMIN (Dashboard, Utilizadores, Pedidos) - SÓ ADMIN/GESTOR -->
                        @if (User.IsInRole("Admin") || User.IsInRole("Gestor"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock-fill"></i> Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Dashboard">
                                            <i class="bi bi-bar-chart-fill"></i> @Localizer["Dashboard"]
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-page="/Admin/Users">
                                                <i class="bi bi-people"></i> Utilizadores
                                            </a>
                                        </li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-page="/Admin/Pedidos">
                                            <i class="bi bi-box-seam"></i> Pedidos
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        
                        <!-- LINKS DIRETOS -->
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Pecas/Index">
                                <i class="bi bi-grid-fill"></i> @Localizer["Catalog"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Carrinho">
                                <i class="bi bi-cart-fill"></i> @Localizer["Cart"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Comparador">
                                <i class="bi bi-arrow-left-right"></i> Comparador
                            </a>
                        </li>
                    </ul>
                    
                    <!-- MENU DIREITA -->
                    <ul class="navbar-nav align-items-center">
                        <!-- DARK MODE TOGGLE -->
                        <li class="nav-item mx-2">
                            <button id="darkModeToggle" class="btn btn-outline-light dark-mode-toggle" title="Alternar Modo Escuro">
                                <i class="bi bi-moon-stars-fill"></i>
                            </button>
                        </li>
                        
                        <!-- SELETOR DE IDIOMA -->
                        <li class="nav-item dropdown language-selector me-3">
                            <button class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                @switch(currentCulture)
                                {
                                    case "en":
                                        <span>🇬🇧 EN</span>
                                        break;
                                    case "es":
                                        <span>🇪🇸 ES</span>
                                        break;
                                    case "fr":
                                        <span>🇫🇷 FR</span>
                                        break;
                                    default:
                                        <span>🇵🇹 PT</span>
                                        break;
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item @(currentCulture == "pt" ? "active" : "")" 
                                       href="/Language/Change?culture=pt&returnUrl=@Uri.EscapeDataString(returnUrl)">
                                        🇵🇹 Português
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item @(currentCulture == "en" ? "active" : "")" 
                                       href="/Language/Change?culture=en&returnUrl=@Uri.EscapeDataString(returnUrl)">
                                        🇬🇧 English
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item @(currentCulture == "es" ? "active" : "")" 
                                       href="/Language/Change?culture=es&returnUrl=@Uri.EscapeDataString(returnUrl)">
                                        🇪🇸 Español
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item @(currentCulture == "fr" ? "active" : "")" 
                                       href="/Language/Change?culture=fr&returnUrl=@Uri.EscapeDataString(returnUrl)">
                                        🇫🇷 Français
                                    </a>
                                </li>
                            </ul>
                        </li>
                        
                        <!-- LOGIN PARTIAL -->
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>🏍️ MotoPartsShop</h5>
                    <p>@Localizer["Welcome"] ao melhor catálogo de peças para motas!</p>
                </div>
                <div class="col-md-6 text-md-end">
                    &copy; 2025 - MotoPartsShop - <a asp-area="" asp-page="/Privacy">Privacy</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
    
    <!-- DARK MODE SCRIPT -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const darkModeToggle = document.getElementById('darkModeToggle');
            const body = document.body;
            const icon = darkModeToggle.querySelector('i');
            
            // Verificar preferência guardada
            const darkMode = localStorage.getItem('darkMode');
            if (darkMode === 'enabled') {
                body.classList.add('dark-mode');
                icon.classList.remove('bi-moon-stars-fill');
                icon.classList.add('bi-sun-fill');
            }
            
            // Toggle ao clicar
            darkModeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-mode');
                
                if (body.classList.contains('dark-mode')) {
                    localStorage.setItem('darkMode', 'enabled');
                    icon.classList.remove('bi-moon-stars-fill');
                    icon.classList.add('bi-sun-fill');
                    
                    darkModeToggle.style.transform = 'rotate(360deg)';
                    setTimeout(() => {
                        darkModeToggle.style.transform = 'rotate(0deg)';
                    }, 300);
                } else {
                    localStorage.setItem('darkMode', 'disabled');
                    icon.classList.remove('bi-sun-fill');
                    icon.classList.add('bi-moon-stars-fill');
                    
                    darkModeToggle.style.transform = 'rotate(-360deg)';
                    setTimeout(() => {
                        darkModeToggle.style.transform = 'rotate(0deg)';
                    }, 300);
                }
            });
        });
    </script>
    <!-- REMOVER BADGE ORIGINAL DO PERFIL -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Remove todas as badges da navbar
        const navbarBadges = document.querySelectorAll('.navbar-nav .badge');
        navbarBadges.forEach(badge => {
            badge.remove();
        });
    });
</script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>