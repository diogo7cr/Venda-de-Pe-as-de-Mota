@page
@using MotoPartsShop.Models
@model MotoPartsShop.Pages.MeusPedidosModel

@{
    ViewData["Title"] = "Os Meus Pedidos";
}

<div class="container py-5">
    <h1 class="display-5 fw-bold mb-4">
        <i class="bi bi-bag-check-fill text-primary"></i> Os Meus Pedidos
    </h1>

    @if (Model.Pedidos.Any())
    {
        @foreach (var pedido in Model.Pedidos)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <strong>Pedido #@pedido.Id</strong><br>
                            <small class="text-muted">@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div class="col-md-3">
                            @switch (pedido.Estado)
                            {
                                case "Pendente":
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock"></i> Pendente
                                    </span>
                                    break;
                                case "Processando":
                                    <span class="badge bg-info">
                                        <i class="bi bi-gear"></i> Processando
                                    </span>
                                    break;
                                case "Enviado":
                                    <span class="badge bg-primary">
                                        <i class="bi bi-truck"></i> Enviado
                                    </span>
                                    break;
                                case "Entregue":
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle"></i> Entregue
                                    </span>
                                    break;
                                case "Cancelado":
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle"></i> Cancelado
                                    </span>
                                    break;
                            }
                        </div>
                        <div class="col-md-3">
                            <strong class="text-success">€@pedido.Total</strong>
                        </div>
                        <div class="col-md-3 text-end">
                            <button class="btn btn-sm btn-outline-primary" type="button" 
                                    data-bs-toggle="collapse" data-bs-target="#pedido-@pedido.Id">
                                <i class="bi bi-eye"></i> Ver Detalhes
                            </button>
                        </div>
                    </div>
                </div>
                
                <div id="pedido-@pedido.Id" class="collapse">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Itens do Pedido:</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Peça</th>
                                        <th>Preço Unit.</th>
                                        <th>Quantidade</th>
                                        <th>Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (pedido.Itens != null && pedido.Itens.Any())
                                    {
                                        @foreach (var item in pedido.Itens)
                                        {
                                            <tr>
                                                <td>@item.NomePeca</td>
                                                <td>€@item.PrecoUnitario</td>
                                                <td>@item.Quantidade</td>
                                                <td><strong>€@item.Subtotal</strong></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted">
                                                Sem itens neste pedido
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="fw-bold">Dados de Envio:</h6>
                                <p class="mb-1"><strong>Nome:</strong> @pedido.NomeCliente</p>
                                <p class="mb-1"><strong>Email:</strong> @pedido.Email</p>
                                <p class="mb-1"><strong>Telefone:</strong> @pedido.Telefone</p>
                                <p class="mb-1"><strong>Morada:</strong> @pedido.Morada</p>
                                <p class="mb-1"><strong>Código Postal:</strong> @pedido.CodigoPostal</p>
                                <p class="mb-1"><strong>Cidade:</strong> @pedido.Cidade</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold">Pagamento:</h6>
                                <p class="mb-1"><strong>Método:</strong> @pedido.MetodoPagamento</p>
                                <p class="mb-1"><strong>Total:</strong> <span class="text-success fw-bold">€@pedido.Total</span></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Ainda não tens pedidos</h4>
            <p>Explora o nosso catálogo e faz a tua primeira compra!</p>
            <a asp-page="/Pecas/Index" class="btn btn-primary mt-3">
                <i class="bi bi-cart"></i> Ver Catálogo
            </a>
        </div>
    }
</div>