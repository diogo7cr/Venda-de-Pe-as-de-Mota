@page
@model MotoPartsShop.Pages.SucessoModel

@{
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg">
                <div class="card-body text-center p-5">
                    <!-- ÍCONE DE SUCESSO -->
                    <div class="success-icon mb-4">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    
                    <h1 class="display-4 fw-bold text-success mb-3">
                        Pedido Confirmado!
                    </h1>
                    
                    @if (Model.PedidoId.HasValue)
                    {
                        <div class="alert alert-info mb-4">
                            <h5 class="mb-0">
                                <i class="bi bi-receipt"></i> 
                                Número do Pedido: <strong>#@Model.PedidoId</strong>
                            </h5>
                        </div>
                    }
                    
                    <p class="lead text-muted mb-4">
                        O teu pedido foi recebido e está a ser processado!
                    </p>
                    
                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <div class="info-box">
                                <i class="bi bi-envelope-fill text-primary"></i>
                                <h6>Email de Confirmação</h6>
                                <p class="small text-muted">Vais receber um email com os detalhes</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <i class="bi bi-truck text-success"></i>
                                <h6>Envio</h6>
                                <p class="small text-muted">Entrega em 3-5 dias úteis</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-3">
                        <a asp-page="/MeusPedidos" class="btn btn-primary btn-lg">
                            <i class="bi bi-list-check"></i> Ver Os Meus Pedidos
                        </a>
                        <a asp-page="/Pecas/Index" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-cart"></i> Continuar a Comprar
                        </a>
                        <a asp-page="/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-house"></i> Voltar à Página Inicial
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .success-icon i {
        font-size: 100px;
        color: #06D6A0;
        animation: scaleIn 0.5s ease;
    }
    
    @@keyframes scaleIn {
        from {
            transform: scale(0);
            opacity: 0;
        }
        to {
            transform: scale(1);
            opacity: 1;
        }
    }
    
    .info-box {
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 10px;
    }
    
    .info-box i {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
    
    .info-box h6 {
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
</style>